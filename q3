package Questao_3;

public class Linha{
	
	/*	reta (y = ax + b)
		coef angular = a
		coef linear = b */

	double cfAngular;
	double cfLinear;

	// contrutores
	public Linha(double cfAgular, double cfLinear) {
		this.cfAngular = cfAgular;
		this.cfLinear = cfLinear;
	}

	// a = (y2 - y1) / (x2 - x1)  [cfAngular]  b = y - mx [cfLinear]
	public Linha(Ponto2D p1, Ponto2D p2) {
		double a = (p2.getY() - p1.getY()) / (p2.getX() - p1.getX());
		double b = p1.getY() - a * p1.getX();
		
		this.cfAngular = a;
		this.cfLinear = b;
	}

	// get & set
	public double getCfAngular() {
		return cfAngular;
	}
	public double getCfLinear() {
		return cfLinear;
	}
	public void setCfAngular(double cfAngular) {
		this.cfAngular = cfAngular;
	}
	public void setCfLinear(double cfLinear) {
		this.cfLinear = cfLinear;
	}

	/*	metodo verificar se ponto pertence a reta
		Calcular se x e o y existem dentro da reta com o coef angular e linear */

	public boolean pertence(Ponto2D ponto) {
		if (ponto.getY() == (cfAngular * ponto.getX() + cfLinear)) {
			return true;
		} else {
			return false;
		}
	}
	
	/*	metodo ponto de interseção entre 2 linhas
		x = (b2 - b1) / (a1 - a2)	*/
	public Ponto2D intersecao(Object obj) {
		
		if (obj == null || !(obj instanceof Linha)) {
			return null;
		}
		
		Linha outra = (Linha) obj;
		
		if (this.cfAngular == outra.cfAngular) {
			return null;
		}
		
		double x = (outra.cfLinear - this.cfLinear) / (this.cfAngular - outra.cfAngular);
		double y = this.cfAngular * x + this.cfLinear;
		
		return new Ponto2D(x, y);
	}
}

package Questao_3;

public class Ponto2D {

	double x;
	double y;


	// Construtores
	public Ponto2D() {
		x = 0;
		y = 0;
	}
	public Ponto2D(double x, double y) {
		this.x = x;
		this.y = y;
	}
	public Ponto2D(Ponto2D outroPonto2D) {
		this.x = outroPonto2D.x;
		this.y = outroPonto2D.y;
	}
	
	//get & set
	public double getX() {
		return x;
	}
	public double getY() {
		return y;
	}
	public void setX(double x) {
		this.x = x;
	}
	public void setY(double y) {
		this.y = y;
	}
	
	// Methodo Equals
	@Override
	public boolean equals(Object obj) {
		if (this == obj) {
			return true;
		}
		if (obj == null || !(obj instanceof Ponto2D)) {
			return false;
		}
		
		Ponto2D outro = (Ponto2D) obj;
		
		return this.x == outro.x && this.y == outro.y;
	}
	
	// Calcular distancia entre 2 pontos
	public double calcDist(Ponto2D outro) {
		return Math.sqrt((outro.x - this.x)*(outro.x - this.x) + (outro.y - this.y)*(outro.y - this.y));
	}
}
